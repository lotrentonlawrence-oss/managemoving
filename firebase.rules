rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isTrentonBusinessEmail() {
      return isAuthenticated() &&
        request.auth.token.email != null &&
        request.auth.token.email.matches("^[Tt][Rr][Ee][Nn][Tt][Oo][Nn]@([Ss][Ww][Ee][Ee][Tt][Hh][Oo][Mm][Ee][Tt][Rr][Aa][Nn][Ss][Ii][Tt][Ii][Oo][Nn][Ss])\\.([Cc][Oo][Mm])$");
    }

    function isTeamByRoleDoc() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "team";
    }

    function isTeam() {
      return isTrentonBusinessEmail() ||
        request.auth.token.team == true ||
        isTeamByRoleDoc();
    }

    function isProjectClient(projectId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/projectMembers/$(request.auth.uid)).data.projectId == projectId;
    }

    match /users/{uid} {
      allow read: if isTeam() || (isAuthenticated() && request.auth.uid == uid);
      allow write: if isTeam();
    }

    match /projectMembers/{uid} {
      allow read: if isTeam() || (isAuthenticated() && request.auth.uid == uid);
      allow write: if isTeam();
    }

    match /projects/{projectId} {
      allow read: if isTeam() || isProjectClient(projectId);
      allow create: if isAuthenticated();
      allow update, delete: if isTeam();

      match /floorPlanItems/{itemId} {
        allow read: if isTeam() || isProjectClient(projectId);
        allow write: if isTeam();
      }

      match /auctionItems/{itemId} {
        allow read: if isTeam() || isProjectClient(projectId);
        allow write: if isTeam();
      }

      match /timeEntries/{entryId} {
        allow read: if isTeam() || isProjectClient(projectId);
        allow write: if isTeam();
      }
    }
  }
}
